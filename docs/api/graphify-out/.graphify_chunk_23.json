      "id": "NavMovementInterface",
      "type": "interface",
      "name": "NavMovementInterface",
      "description": "Nav Movement Interface",
      "source": {
        "module": "Engine",
        "file": "NavMovementInterface.h"
      },
      "inherits_from": ["Interface"],
      "methods": [
        {"name": "stop_movement_keep_pathing", "return_type": "None", "description": "Stops movement immediately (reset velocity) but keeps following current path"},
        {"name": "stop_active_movement", "return_type": "None", "description": "Stops applying further movement (usually zeros acceleration)"},
        {"name": "request_path_move", "return_type": "None", "parameters": [{"name": "move_input", "type": "Vector"}], "description": "path following: request movement through a new move input"},
        {"name": "request_direct_move", "return_type": "None", "parameters": [{"name": "move_velocity", "type": "Vector"}, {"name": "force_max_speed", "type": "bool"}], "description": "path following: request movement through a velocity directly"},
        {"name": "is_swimming", "return_type": "bool", "description": "Returns true if currently swimming"},
        {"name": "is_moving_on_ground", "return_type": "bool", "description": "Returns true if currently moving on the ground"},
        {"name": "is_flying", "return_type": "bool", "description": "Returns true if currently flying"},
        {"name": "is_falling", "return_type": "bool", "description": "Returns true if currently falling"},
        {"name": "is_crouching", "return_type": "bool", "description": "Returns true if currently crouching"},
        {"name": "get_velocity_for_nav_movement", "return_type": "Vector", "description": "Get the current velocity of the agent for nav movement"},
        {"name": "get_max_speed_for_nav_movement", "return_type": "float", "description": "Get maximum movement speed of the agent"}
      ]
