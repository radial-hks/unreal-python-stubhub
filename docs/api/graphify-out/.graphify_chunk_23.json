    {
      "id": "ButtonClickMethod",
      "type": "enum",
      "name": "ButtonClickMethod",
      "description": "Enumerates different methods that a button click can be triggered",
      "source": {
        "module": "SlateCore",
        "file": "SlateEnums.h"
      },
      "inherits_from": ["EnumBase"],
      "values": [
        {"name": "DOWN_AND_UP", "value": 0, "description": "User must press the button, then release while over the button to trigger the click"},
        {"name": "MOUSE_DOWN", "value": 1, "description": "Click will be triggered immediately on mouse down, and mouse will not be captured"},
        {"name": "MOUSE_UP", "value": 2, "description": "Click will always be triggered when mouse button is released over the button"},
        {"name": "PRECISE_CLICK", "value": 3, "description": "Inside a list, buttons can only be clicked with precise tap"}
      ]
    },
