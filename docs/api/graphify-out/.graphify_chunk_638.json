      "label": "SpawnActorCollisionHandlingMethod",
      "description": "Defines available strategies for handling the case where an actor is spawned in such a way that it penetrates blocking collision",
      "module": "Engine",
      "file": "EngineTypes.h",
      "values": [
        {"name": "UNDEFINED", "value": 0, "description": "Fall back to default settings"},
        {"name": "ALWAYS_SPAWN", "value": 1, "description": "Actor will spawn in desired location, regardless of collisions"},
        {"name": "ADJUST_IF_POSSIBLE_BUT_ALWAYS_SPAWN", "value": 2, "description": "Actor will try to find a nearby non-colliding location, but will always spawn even if one cannot be found"},
        {"name": "ADJUST_IF_POSSIBLE_BUT_DONT_SPAWN_IF_COLLIDING", "value": 3, "description": "Actor will try to find a nearby non-colliding location, but will NOT spawn unless one is found"},
        {"name": "DONT_SPAWN_IF_COLLIDING", "value": 4, "description": "Actor will fail to spawn"}
      ]
    },
