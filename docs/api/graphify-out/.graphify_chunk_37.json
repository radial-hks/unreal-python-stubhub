      "type": "enum",
      "label": "GameplayEffectPeriodInhibitionRemovedPolicy",
      "description": "Enumeration of policies for dealing with the period of a gameplay effect when inhibition is removed",
      "source": {
        "plugin": "GameplayAbilities",
        "module": "GameplayAbilities",
        "file": "GameplayEffect.h"
      },
      "values": [
        {"name": "NEVER_RESET", "value": 0, "description": "Does not reset. The period timing will continue as if the inhibition hadn't occurred."},
        {"name": "RESET_PERIOD", "value": 1, "description": "Resets the period. The next execution will occur one full period from when inhibition is removed."},
        {"name": "EXECUTE_AND_RESET_PERIOD", "value": 2, "description": "Executes immediately and resets the period."}
      ]
    }
